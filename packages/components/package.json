{
  "name": "@ytsaurus/components",
  "version": "0.2.1",
  "private": false,
  "description": "YTsaurus UI component library: navigation table, data display (Yson, Schema, DataTable), navigation API and shared config",
  "repository": {
    "type": "github",
    "url": "https://github.com/ytsaurus/ytsaurus-ui/tree/main/packages/components"
  },
  "files": [
    "build/esm",
    "src/styles",
    "README.ru.md"
  ],
  "main": "./build/esm/index.js",
  "module": "./build/esm/index.js",
  "types": "./build/esm/index.d.ts",
  "typesVersions": {
    "*": {
      "modules": [
        "./build/esm/modules/index.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./build/esm/index.d.ts",
      "default": "./build/esm/index.js"
    },
    "./modules": {
      "types": "./build/esm/modules/index.d.ts",
      "default": "./build/esm/modules/index.js"
    }
  },
  "scripts": {
    "deps:install": "npm ci",
    "build": "app-builder build --config ./app-builder.config.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "jest --config ./jest.config.js --passWithNoTests",
    "storybook": "storybook dev -p 6006 --no-open",
    "build:storybook": "storybook build",
    "test:components:impl": "playwright test -c src/playwright-components/playwright.config.ts ${PW_OPTIONS}",
    "test:components": "scripts/docker-run.sh npm run test:components:impl",
    "test:components:update": "scripts/docker-run.sh npm run test:components:impl -- -u",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@gravity-ui/date-utils": ">=2.0.0",
    "@gravity-ui/icons": ">=2.0.0",
    "@gravity-ui/table": ">=1.0.0",
    "@gravity-ui/uikit": ">=7.0.0",
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "devDependencies": {
    "@babel/preset-react": "^7.26.3",
    "@babel/preset-typescript": "^7.26.0",
    "@gravity-ui/app-builder": "^0.26.0",
    "@gravity-ui/date-utils": "^2.6.0",
    "@gravity-ui/eslint-config": "^3.2.0",
    "@gravity-ui/icons": "^2.0.0",
    "@gravity-ui/prettier-config": "^1.1.0",
    "@gravity-ui/table": "^1.15.2",
    "@gravity-ui/tsconfig": "^1.0.0",
    "@gravity-ui/uikit": "^7.0.0",
    "@playwright/experimental-ct-react": "1.53.1",
    "@playwright/test": "1.53.1",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/react": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@types/jest": "^29.5.5",
    "@types/lodash": "^4.17.24",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.6.0",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "jest-extended": "^4.0.1",
    "prettier": "^3.7.4",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "storybook": "^10.3.5",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0",
    "vite": "^6.4.2",
    "vite-plugin-commonjs": "^0.10.4",
    "vite-plugin-svgr": "^5.2.0"
  },
  "dependencies": {
    "@gravity-ui/i18n": "^1.8.0",
    "@gravity-ui/illustrations": "^2.1.0",
    "@gravity-ui/react-data-table": "^2.2.1",
    "@gravity-ui/unipika": "^5.1.0",
    "@ytsaurus/interface-helpers": "^1.2.0",
    "@ytsaurus/javascript-wrapper": "^0.17.0",
    "axios": "^1.13.6",
    "bem-cn-lite": "^4.1.0",
    "bignumber.js": "^9.3.0",
    "hotkeys-js": "^3.13.15",
    "lodash": "^4.17.21"
  }
}
