{
  "name": "@ytsaurus/components",
  "version": "0.1.0",
  "private": false,
  "description": "YTsaurus UI component library: navigation table, data display (Yson, Schema, DataTable), navigation API and shared config",
  "repository": {
    "type": "github",
    "url": "https://github.com/ytsaurus/ytsaurus-ui/tree/main/packages/yt-components"
  },
  "files": [
    "build/esm"
  ],
  "main": "./build/esm/index.js",
  "module": "./build/esm/index.js",
  "types": "./build/esm/index.d.ts",
  "typesVersions": {
    "*": {
      "modules": [
        "./build/esm/modules/index.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./build/esm/index.d.ts",
      "default": "./build/esm/index.js"
    },
    "./modules": {
      "types": "./build/esm/modules/index.d.ts",
      "default": "./build/esm/modules/index.js"
    }
  },
  "scripts": {
    "deps:install": "npm ci",
    "build": "app-builder build --config ./app-builder.config.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "jest --config ./jest.config.js",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@gravity-ui/icons": ">=2.0.0",
    "@gravity-ui/table": ">=1.0.0",
    "@gravity-ui/uikit": ">=7.0.0",
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "devDependencies": {
    "@gravity-ui/app-builder": "^0.26.0",
    "@gravity-ui/eslint-config": "^3.2.0",
    "@gravity-ui/icons": "^2.0.0",
    "@gravity-ui/prettier-config": "^1.1.0",
    "@gravity-ui/table": "^1.15.2",
    "@gravity-ui/tsconfig": "^1.0.0",
    "@gravity-ui/uikit": "^7.0.0",
    "@types/jest": "^29.5.5",
    "@types/lodash": "^4.17.24",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "jest-extended": "^4.0.1",
    "prettier": "^3.7.4",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@gravity-ui/i18n": "^1.8.0",
    "@gravity-ui/illustrations": "^2.1.0",
    "@gravity-ui/react-data-table": "^2.2.1",
    "@gravity-ui/unipika": "^5.1.0",
    "@ytsaurus/interface-helpers": "^1.1.1",
    "@ytsaurus/javascript-wrapper": "^0.17.0",
    "axios": "^1.13.6",
    "bem-cn-lite": "^4.1.0",
    "hotkeys-js": "^3.13.15",
    "lodash": "^4.17.21",
    "moment": "^2.30.1"
  }
}
