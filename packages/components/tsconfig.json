{
    "extends": "@gravity-ui/tsconfig/tsconfig.json",
    "compilerOptions": {
        "baseUrl": ".",
        "target": "ES2018",
        "rootDir": "src",
        "outDir": "build",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "declaration": true,
        "declarationMap": true,
        "resolveJsonModule": true,
        "allowSyntheticDefaultImports": true,
        "jsx": "react-jsx",
        "skipLibCheck": true,
        "isolatedModules": true
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "build"]
}
